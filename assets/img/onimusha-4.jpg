:host .button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  outline: none;
  cursor: pointer;
  font-weight: 500;
  border-radius: 3px;
  padding: 0 16px;
  border-radius: 4px;
  color: var(--dark);
  background: var(--green);
  line-height: 1;
  font-size: 14px;
  height: 32px;
  word-spacing: 0px;
  letter-spacing: 0.0892857143em;
  text-decoration: none;
  text-transform: uppercase;
  min-width: 64px;
  border: none;
  text-align: center;
  box-shadow: 0px 3px 1px -2px rgb(0 0 0 / 20%),
    0px 2px 2px 0px rgb(0 0 0 / 14%), 0px 1px 5px 0px rgb(0 0 0 / 12%);
  transition: box-shadow 280ms cubic-bezier(0.4, 0, 0.2, 1);
}

:host button:hover,
:host .button:hover {
  background: var(--light-green);
  box-shadow: 0px 2px 4px -1px rgb(0 0 0 / 20%),
    0px 4px 5px 0px rgb(0 0 0 / 14%), 0px 1px 10px 0px rgb(0 0 0 / 12%);
}

:host button.primary,
:host .button.primary {
  color: #fff;
  background: var(--pink);

  box-shadow: 0px 3px 1px -2px rgb(0 0 0 / 20%),
    0px 2px 2px 0px rgb(0 0 0 / 14%), 0px 1px 5px 0px rgb(0 0 0 / 12%);
}

:host button:hover,
:host button.primary:hover,
:host .button.primary:hover {
  background: var(--pink);
  box-shadow: 0px 2px 4px -1px rgb(0 0 0 / 20%),
    0px 4px 5px 0px rgb(0 0 0 / 14%), 0px 1px 10px 0px rgb(0 0 0 / 12%);
}

:host button.secondary,
:host .button.secondary {
  color: var(--pink);
  background: transparent;
  text-decoration: none;
  text-transform: uppercase;

  border: 1px solid var(--pink);

  transition: background 280ms cubic-bezier(0.4, 0, 0.2, 1);
}

:host button.secondary:hover,
:host .button.secondary:hover {
  background: var(--white);
}

:host .button:disabled {
  opacity: 0.85;
  cursor: not-allowed;
}
</style><style>:root,
:host {
  /* --pink: #f7559a;
  --light-pink: #f986b7; 
  --light-gray: #b3b3b3;
  --black: #111111;
  --green: #81e4c4;
  --light-green: #abedd8;
  --lighter-green: #d5f6eb;
  */

  --pink: #614ffb;
  --dark-pink: #130253;
  --dark: #120053;
  --gray: #868686;
  --light-gray: #b3b3b3;

  --lighter-gray: #e3e3e3;
  --black: #111111;
  --green: #95efd1;
  --light-green: #abedd8;
  --lighter-green: #d5f6eb;
  --white: #ffffff;

  --text: var(--dark);

  --selection: #3297fd;
  --selectionRgb: rgb(50, 151, 253);
  --selectionRgba: rgb(50, 151, 253, 0.1);
  --yellow: #ffbb09;
  --yellow-light: #ffc93c;
  --yellow-lighter: #ffd76f;
  --black: #000000;
  --black-light: #111111;
  --black-lighter: #2a2a2a;
  --box-shadow-color: rgba(42, 42, 4, 0.1);
  --box-shadow: 0px 0px 16px var(--box-shadow-color);
  --border-gray: #e8e8e8;

  --warning: #f2a600;
  --success: #12c99b;
  --error: #e41749;
  --font-size: 16px;
  --z-index: 2147483647;
  color: var(--text);
  font-size: var(--font-size);

  font-family: "Roboto", sans-serif;
}

* {
  box-sizing: border-box;
}

/* custom scroll */
/* ::-webkit-scrollbar {
  background-color: var(--white);
  width: 16px;
}
::-webkit-scrollbar-track {
  background-color: var(--white);
}
::-webkit-scrollbar-thumb {
  background-color: #babac0;
  border-radius: 16px;
  border: 4px solid var(--white);
}
::-webkit-scrollbar-button {
  display: none;
} */

html ::-webkit-scrollbar {
  width: 16px;
}
/* var(--ytcp-icon-disabled) */
/* var(--ytcp-icon-inactive); */
html ::-webkit-scrollbar-thumb {
  height: 56px;
  border-radius: 8px;
  border: 4px solid transparent;
  background-clip: content-box;
  background-color: var(--light-gray);
}

html ::-webkit-scrollbar-thumb:hover {
  background-color: var(--light-gray);
}

@supports (scrollbar-width: thin) {
  * {
    scrollbar-width: thin;
    scrollbar-color: var(--light-gray) transparent;
  }
}
</style><style>.app-page-loader {
  width: 100vw;
  height: 5px;
  top: 0;
  position: fixed;
  z-index: var(--z-index);
}
.app-page-loader .loader-line {
  width: 100%;
  height: 4px;
  position: relative;
  overflow: hidden;
  background-color: #ddd;
  margin: 0 auto;
  border-radius: 0px;
}

.app-page-loader .loader-line:before {
  content: "";
  position: absolute;
  left: -50%;
  height: 4px;
  width: 40%;
  background-color: var(--pink);

  animation: lineAnim 2s linear infinite;

  border-radius: 0px;
}

@keyframes lineAnim {
  0% {
    left: -40%;
  }
  50% {
    left: 20%;
    width: 80%;
  }
  100% {
    left: 100%;
    width: 100%;
  }
}
</style><style>.polygon {
  position: fixed;
  cursor: crosshair;
  top: 0;
  bottom: 0;
  right: 0;
  left: 0;
  background-color: transparent;
  z-index: calc(var(--z-index) - 1);
  border: 2px dashed var(--selectionRgb);
  box-sizing: border-box;
}

.polygon.polygon__selecting {
  pointer-events: initial;
}

.polygon.polygon__default,
.polygon.polygon__selecting,
.polygon.polygon__selecting-invalid {
  background: var(--selectionRgba);
}

.polygon.polygon__capturing,
.polygon.polygon__loading {
  /* background-color: transparent;
    opacity: 1; */
  background: transparent;
  outline-style: dashed;
  cursor: progress;
}

/*selected rect */
.polygon .select-rect {
  outline: var(--yellow) 2px;
  outline-style: dashed;
}

.polygon .select-rect.select-rect__selecting {
}
.polygon .select-rect.select-rect__selecting-invalid {
  outline-color: var(--error);
}
.polygon .select-rect.select-rect__capturing {
  animation: shake 1s infinite ease-in-out alternate;
}
.polygon .select-rect.select-rect__captured {
  outline-color: var(--success);
}

/* captured  result  */
.captured-result {
  position: absolute;
  top: 0;
  bottom: 0;
  right: 0;
  left: 0;
  background: rgb(50, 151, 253, 0);
}

.captured-result .answer {
    position: absolute;
    top: 4px;
    left: 4px;
    right: 4px;
    background: var(--success);
    color: var(--white);
    padding: 8px;
    border-radius: 4px;
    cursor: auto;
}

.captured-result .actions {
  position: absolute;
  background: var(--success);
  color: white;
}

.captured-result .actions.actions__top {
  top: 0;
  right: -1px;
  transform: translate(0, calc(-100%));
  display: flex;
  flex-direction: row-reverse;
  height: 20px;
  border-radius: 4px 4px 0 0;
}

.captured-result .actions.actions__bottom {
  bottom: 0;
  right: -1px;
  transform: translate(0, calc(100%));
  display: flex;
  flex-direction: row-reverse;
  height: 20px;
  border-radius: 0px 0px 4px 4px;
}

.captured-result .actions.actions__right {
  top: 4px;
  right: 0;
  transform: translate(calc(100%), 0);
  display: flex;
  flex-direction: column;
  width: 20px;
  border-radius: 0px 4px 4px 0px;
}

.captured-result .actions.actions__left {
  top: 4px;
  left: 0;
  transform: translate(calc(-100%), 0);
  display: flex;
  flex-direction: column;
  width: 20px;
  border-radius: 4px 0px 0px 4px;
}
.captured-result .actions.actions__right-inside {
  top: 4px;
  right: 0;
  transform: translate(0, 0);
  display: flex;
  flex-direction: column;
  width: 20px;
  border-radius: 4px 0px 0px 4px;
}

.captured-result .actions i {
  cursor: pointer;
}
.captured-result .actions i:hover {
  zoom: 1.1;
}
.captured-result .actions .actions_icon-wrap {
  width: 20px;
  height: 20px;
}

.captured-result svg {
  width: 100%;
  height: 100%;
}
.captured-result svg text {
  background: rgba(255, 255, 255, 1);
  z-index: 1;
}
@keyframes shake {
  from,
  to {
    transform: translate3d(0, 0, 0);
    opacity: 1;
  }

  10%,
  30%,
  70%,
  90% {
    /* transform: translate3d(-2px, 0, 0); */
  }
  50% {
    opacity: 0.4;
    /* transform: translate3d(-2px, 0, 0); */
  }
}
</style><style></style><style>.notify {
  display: block;
  width: 100%;
  min-height: 60px;
  background-color: var(--white);
  border-radius: 5px;
}
</style><style>.buddy-think-answer {
  padding: 8px 16px;
  background-color: var(--light-green);
  border-radius: 5px;
  border: 1px solid var(--green);
  font-weight: bolder;
}
.buddy-think-random {
}
</style><style>.notify {
  display: block;
  width: 100%;
  min-height: 60px;
  background-color: var(--white);
  border-radius: 5px;
  padding: 0;
  box-shadow: 0px 0px 16px var(--pink);
}

.notify_main {
  padding: 0 8px;
}

.notify_header {
  padding: 8px 8px 0 8px;
  border-bottom: 2px solid var(--light-pink);
  font-weight: bolder;
  border-radius: 5px 5px 0 0;
  box-sizing: border-box;
}
.notify_footer {
  padding: 8px 8px 8px 8px;
  display: flex;
  flex-direction: row;
  gap: 10px;
  justify-content: end;
  border-radius: 0 0 5px 5px;
  background: linear-gradient(
    135deg,
    rgba(97, 79, 251, 0.2),
    rgba(149, 239, 209, 0.2)
  );
}
</style><style>.quiz-page-ask-me {
}
.quiz-page-ask-me.quiz-page-ask-me_wrap {
  position: fixed;
  top: 20%;
  left: 0;
}

.quiz-page-ask-me button.quiz-page-ask-me_btn {
  width: 50px;
  height: 40px;
  min-width: 50px;
  min-height: 40px;
  padding: 8px;
  border-radius: 0 8px 8px 0;
  background: rgb(240, 94, 157);
  background: linear-gradient(
    90deg,
    rgba(240, 94, 157, 0.7) 33%,
    rgba(85, 245, 193, 0.7792366946778712) 65%
  );
  background-size: 200% 200%;
  background-position: 50% 100%;
  
}

.quiz-page-ask-me.quiz-page-ask-me__loading button.quiz-page-ask-me_btn {
  animation: bgAnimation 1.5s ease infinite;
}

@keyframes bgAnimation {
  0% {
    background-position: 50% 100%;
  }
  50% {
    background-position: 91% 100%;
  }
  100% {
    background-position: 10% 0%;
  }
}
